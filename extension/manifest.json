{
  "manifest_version": 3,
  "name": "My MERN Extension",
  "version": "1.0.0",
  "description": "A full-stack MERN Chrome extension",
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "tabs"
  ],
  "oauth2": {
    "client_id": "351066743997-pemo30qsjtnriqg9ra151r9b2dqjdmnn.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ]
}