{
  "manifest_version": 3,
  "name": "TodoExt",
  "version": "1.0.0",
  "description": "Manage your todos while browsing — save tasks directly from any webpage.",
  "permissions": [
    "storage",
    "activeTab",
    "identity",
    "tabs"
  ],
  "oauth2": {
    "client_id": "351066743997-pemo30qsjtnriqg9ra151r9b2dqjdmnn.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "host_permissions": [
    "https://to-do-extention.onrender.com/*"
  ],
  "icons": {
    "16":  "icons/16.png",
    "48":  "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16":  "icons/16.png",
      "48":  "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.js"],
      "run_at": "document_idle"
    }
  ]
}